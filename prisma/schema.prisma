// ── BLOG module (blog-be-1) ──────────────────────────────────────────────
// Editorial articles (see docs/srs/blog.md §8). `Article` extends ContentBase +
// embeds SeoMeta. Unlike Projects/Services the rich content is a single JSONB
// `body` block document (lead split out as `body_lead`; §8.2) rather than child
// tables — `img` blocks reference MediaAssets by id inside the JSON (so MEDIA's
// delete-guard text-scans the body). `category` is a nullable FK to the SITE
// blog-category vocabulary; `tags` are freeform. `article_date` (editorial) is
// independent of `published_at` (workflow, BR-4). Related articles are auto-derived
// (same category → recent), not stored. read_time is derived unless overridden.

model Article {
  id                 String        @id @default(uuid()) @db.Uuid
  status             ContentStatus @default(draft)
  publishedAt        DateTime?     @map("published_at")
  legacyId           String?       @unique @map("legacy_id")
  slug               String        @unique
  title              String
  excerpt            String?
  coverImageId       String?       @map("cover_image") @db.Uuid
  coverImage         MediaAsset?   @relation("ArticleCoverImage", fields: [coverImageId], references: [id], onDelete: SetNull)
  categoryId         String?       @map("category_id") @db.Uuid
  category           TaxonomyTerm? @relation("ArticleCategory", fields: [categoryId], references: [id], onDelete: Restrict)
  tags               String[]
  authorName         String?       @map("author_name")
  authorRole         String?       @map("author_role")
  authorBio          String?       @map("author_bio")
  articleDate        DateTime?     @map("article_date") @db.Date
  readTimeMinutes    Int?          @map("read_time_minutes")
  featured           Boolean       @default(false)
  popularity         Int           @default(0)
  bodyLead           String?       @map("body_lead")
  body               Json?
  // Embedded SeoMeta (overview §6.2)
  seoMetaTitle       String?       @map("seo_meta_title")
  seoMetaDescription String?       @map("seo_meta_description")
  seoCanonicalUrl    String?       @map("seo_canonical_url")
  seoOgImageId       String?       @map("seo_og_image") @db.Uuid
  seoOgImage         MediaAsset?   @relation("ArticleSeoOgImage", fields: [seoOgImageId], references: [id], onDelete: SetNull)
  seoOgTitle         String?       @map("seo_og_title")
  seoOgDescription   String?       @map("seo_og_description")
  seoNoindex         Boolean       @default(false) @map("seo_noindex")
  // Audit (ContentBase)
  createdById        String?       @map("created_by") @db.Uuid
  updatedById        String?       @map("updated_by") @db.Uuid
  createdBy          User?         @relation("ArticleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy          User?         @relation("ArticleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  deletedAt          DateTime?     @map("deleted_at")

  @@index([status])
  @@index([categoryId])
  @@index([featured])
  @@index([articleDate])
  @@index([deletedAt])
  @@map("articles")
}

// ── NEWS module (news-be-1) ──────────────────────────────────────────────
// The "News Corner" (see docs/srs/news.md §8). Blog's close sibling — `NewsStory`
// extends ContentBase + embeds SeoMeta, with a JSONB `body` block document, but the
// body is a FLAT block list (h2/h3/p/ul/quote/callout/img) and there is NO author
// (BR-9 — SITE newsroom byline) and NO popularity. Adds an ordered `gallery` child
// table. category → SITE news-category vocab; tags freeform; article_date editorial
// (BR-4); related auto-derived; read_time derived/overridable.

model NewsStory {
  id                 String            @id @default(uuid()) @db.Uuid
  status             ContentStatus     @default(draft)
  publishedAt        DateTime?         @map("published_at")
  legacyId           String?           @unique @map("legacy_id")
  slug               String            @unique
  title              String
  excerpt            String?
  coverImageId       String?           @map("cover_image") @db.Uuid
  coverImage         MediaAsset?       @relation("NewsStoryCoverImage", fields: [coverImageId], references: [id], onDelete: SetNull)
  categoryId         String?           @map("category_id") @db.Uuid
  category           TaxonomyTerm?     @relation("NewsStoryCategory", fields: [categoryId], references: [id], onDelete: Restrict)
  tags               String[]
  articleDate        DateTime?         @map("article_date") @db.Date
  readTimeMinutes    Int?              @map("read_time_minutes")
  featured           Boolean           @default(false)
  bodyLead           String?           @map("body_lead")
  body               Json?
  gallery            NewsGalleryItem[]
  // Embedded SeoMeta (overview §6.2)
  seoMetaTitle       String?           @map("seo_meta_title")
  seoMetaDescription String?           @map("seo_meta_description")
  seoCanonicalUrl    String?           @map("seo_canonical_url")
  seoOgImageId       String?           @map("seo_og_image") @db.Uuid
  seoOgImage         MediaAsset?       @relation("NewsStorySeoOgImage", fields: [seoOgImageId], references: [id], onDelete: SetNull)
  seoOgTitle         String?           @map("seo_og_title")
  seoOgDescription   String?           @map("seo_og_description")
  seoNoindex         Boolean           @default(false) @map("seo_noindex")
  createdById        String?           @map("created_by") @db.Uuid
  updatedById        String?           @map("updated_by") @db.Uuid
  createdBy          User?             @relation("NewsStoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy          User?             @relation("NewsStoryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  deletedAt          DateTime?         @map("deleted_at")

  @@index([status])
  @@index([categoryId])
  @@index([featured])
  @@index([articleDate])
  @@index([deletedAt])
  @@map("news_stories")
}

model NewsGalleryItem {
  id       String     @id @default(uuid()) @db.Uuid
  storyId  String     @map("story_id") @db.Uuid
  story    NewsStory  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  mediaId  String     @map("media_id") @db.Uuid
  media    MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Restrict)
  caption  String?
  position Int        @default(0)

  @@index([storyId])
  @@index([mediaId])
  @@map("news_gallery_items")
}

// ── CERTIFICATIONS module (certifications-be-1) ──────────────────────────
// Credentials/licenses/work-experience records (see docs/srs/certifications.md §8).
// `Certification` extends ContentBase but, uniquely, does NOT embed SeoMeta — there
// is no per-record detail page or public URL (BR-8), so no sitemap/redirect wiring.
// `status` is the ContentBase workflow; `cert_status` is the real-world standing
// (CertStatus). `document` is an optional MediaAsset (scan/PDF). `legacy_ref` is the
// non-unique legacy id (duplicates exist — BR-7), distinct from the generated unique
// `slug`. A curated `show_on_home` subset carries the home-page seal fields + order.

enum CertStatus {
  Active
  Completed
  Expired
  Renewed
}

enum CertTone {
  paper
  slate
  cream
}

enum CertSealShape {
  round
  hex
}

model Certification {
  id           String        @id @default(uuid()) @db.Uuid
  status       ContentStatus @default(draft)
  publishedAt  DateTime?     @map("published_at")
  legacyRef    String?       @map("legacy_ref")
  slug         String        @unique
  title        String
  authority    String?
  number       String?
  categoryId   String?       @map("category_id") @db.Uuid
  category     TaxonomyTerm? @relation("CertificationCategory", fields: [categoryId], references: [id], onDelete: Restrict)
  certStatus   CertStatus    @default(Active) @map("cert_status")
  issuedDate   DateTime?     @map("issued_date") @db.Date
  expiryDate   DateTime?     @map("expiry_date") @db.Date
  description  String?
  documentId   String?       @map("document") @db.Uuid
  document     MediaAsset?   @relation("CertificationDocument", fields: [documentId], references: [id], onDelete: SetNull)
  tone         CertTone      @default(paper)
  sealShape    CertSealShape @default(round) @map("seal_shape")
  showOnHome   Boolean       @default(false) @map("show_on_home")
  sealLabel    String?       @map("seal_label")
  sealId       String?       @map("seal_id")
  sealValidity String?       @map("seal_validity")
  sealOrder    Int?          @map("seal_order")
  createdById  String?       @map("created_by") @db.Uuid
  updatedById  String?       @map("updated_by") @db.Uuid
  createdBy    User?         @relation("CertificationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?         @relation("CertificationUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  deletedAt    DateTime?     @map("deleted_at")

  @@index([status])
  @@index([categoryId])
  @@index([certStatus])
  @@index([showOnHome, sealOrder])
  @@index([deletedAt])
  @@map("certifications")
}

// ── CONCERNS module (concerns-be-1) ──────────────────────────────────────
// Group/sister-company profiles (see docs/srs/concerns.md §8). `Concern` extends
// ContentBase + embeds SeoMeta; rich detail page at /concern-detail/<slug>. Exactly
// one published concern is the `is_default` landing (enforced app-side, set-default
// clears the previous). `related` concerns are DERIVED (other published, in order —
// BR-4), not stored. `position` is the app-managed nav order (plain indexed Int).
// Seven ordered child collections cascade-delete; showcase + gallery items carry
// MediaAsset images.

model Concern {
  id                 String                   @id @default(uuid()) @db.Uuid
  status             ContentStatus            @default(draft)
  publishedAt        DateTime?                @map("published_at")
  legacyId           String?                  @unique @map("legacy_id")
  slug               String                   @unique
  name               String
  short              String?
  tagline            String?
  intro              String?
  establishedYear    Int?                     @map("established_year")
  code               String?
  heroImageId        String?                  @map("hero_image") @db.Uuid
  heroImage          MediaAsset?              @relation("ConcernHeroImage", fields: [heroImageId], references: [id], onDelete: SetNull)
  isDefault          Boolean                  @default(false) @map("is_default")
  position           Int                      @default(0)
  overviewTitle      String?                  @map("overview_title")
  overviewBody       String[]                 @map("overview_body")
  overviewMission    String?                  @map("overview_mission")
  // Embedded SeoMeta (overview §6.2)
  seoMetaTitle       String?                  @map("seo_meta_title")
  seoMetaDescription String?                  @map("seo_meta_description")
  seoCanonicalUrl    String?                  @map("seo_canonical_url")
  seoOgImageId       String?                  @map("seo_og_image") @db.Uuid
  seoOgImage         MediaAsset?              @relation("ConcernSeoOgImage", fields: [seoOgImageId], references: [id], onDelete: SetNull)
  seoOgTitle         String?                  @map("seo_og_title")
  seoOgDescription   String?                  @map("seo_og_description")
  seoNoindex         Boolean                  @default(false) @map("seo_noindex")
  // Child collections
  facts              ConcernFact[]
  services           ConcernService[]
  why                ConcernWhy[]
  showcase           ConcernShowcaseProject[]
  process            ConcernProcessStep[]
  gallery            ConcernGalleryItem[]
  faqs               ConcernFaq[]
  // Audit (ContentBase)
  createdById        String?                  @map("created_by") @db.Uuid
  updatedById        String?                  @map("updated_by") @db.Uuid
  createdBy          User?                    @relation("ConcernCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy          User?                    @relation("ConcernUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")
  deletedAt          DateTime?                @map("deleted_at")

  @@index([status])
  @@index([position])
  @@index([isDefault])
  @@index([deletedAt])
  @@map("concerns")
}

model ConcernFact {
  id        String  @id @default(uuid()) @db.Uuid
  concernId String  @map("concern_id") @db.Uuid
  concern   Concern @relation(fields: [concernId], references: [id], onDelete: Cascade)
  big       String
  label     String
