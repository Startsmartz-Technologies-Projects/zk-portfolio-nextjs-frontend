# Copy to .env and fill in. .env is gitignored; this .env.example is committed.

# PostgreSQL — matches docker-compose.yml (postgres/postgres on localhost:5432)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zk_portfolio?schema=public"

# Custom JWT session secret (jose, HS256). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Cloudinary — used by media-be-2; placeholders for now.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Optional: dedicated test database for integration tests (see vitest.config.ts).
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zk_portfolio_test?schema=public"
